<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </com.google.android.material.appbar.AppBarLayout>

    <com.google.android.flexbox.FlexboxLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:dividerDrawable="@drawable/divider_20dp"
        android:layout_margin="16dp"
        app:flexWrap="wrap"
        app:showDivider="middle">

        <Button
            android:id="@+id/button_sql_insert"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="sql_insert" />

        <Button
            android:id="@+id/button_sql_query"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="sql_query" />


        <Button
            android:id="@+id/button_room_insert"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="room_insert" />

        <Button
            android:id="@+id/button_room_query"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="room_query" />

        <Button
            android:id="@+id/button_clear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="clearText"
            app:layout_wrapBefore="true" />
    </com.google.android.flexbox.FlexboxLayout>

    <TextView
        android:id="@+id/text_show"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:background="@color/zui_color_amber_100"
        android:padding="10dp" />
</LinearLayout>
