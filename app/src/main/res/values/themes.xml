<resources>
    <!-- Base application theme. -->
    <style name="Base.Theme.ZuiApp" parent="Theme.Material3.Light.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">#7E57C2</item>
        <item name="colorOnPrimary">#ffffff</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>

        <item name="android:windowAnimationStyle">@style/ActivityAnim</item>
        <item name="android:windowBackground">@color/zui_color_gray_100</item>
    </style>

    <style name="ActivityAnim" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/slide_right_in</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_right_out</item>
    </style>

    <style name="Theme.ZuiApp" parent="Base.Theme.ZuiApp">
    </style>

    <style name="Theme.ZuiApp.SplashTheme" parent="Theme.ZuiApp">

    </style>

    <style name="Theme.ProgressDialog" parent="Theme.Material3.Light.Dialog">
        <item name="colorPrimary">#6750a4</item>
        <item name="colorOnPrimary">#ffffff</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Theme.InputMethodDialog" parent="Theme.Material3.Light.BottomSheetDialog">
        <item name="android:windowIsFloating">true</item>
    </style>

    <attr name="colorOnPrimary" format="color|reference" />

</resources>